    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.5"
  }
